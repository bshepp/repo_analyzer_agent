# GitHub token (optional but recommended; without it, rate limits are ~60/hour).
# Options (in order of use):
#   1. Run `gh auth login` — scout will use GitHub CLI token automatically.
#   2. Set GITHUB_TOKEN here or export it. Create at: https://github.com/settings/tokens
#   3. Pass --token on the command line.
# Scopes: public_repo (or repo for private repos).
GITHUB_TOKEN=
